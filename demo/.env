# MediaRiver Demo Environment
#
# 1. Start MinIO:
#    docker run -d --name mediariver-minio -p 9000:9000 -p 9001:9001 \
#      -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
#      minio/minio server /data --console-address ":9001"
#
# 2. Source this file:
#    export $(grep -v '^#' demo/.env | xargs)
#
# 3. Run demo:
#    mediariver validate --workflows-dir demo/workflows
#    mediariver run --workflows-dir demo/workflows
#
# 4. Check MinIO console: http://localhost:9001 (minioadmin/minioadmin)

S3_BUCKET=demo-bucket
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

BACKEND_URL=http://localhost:8080
